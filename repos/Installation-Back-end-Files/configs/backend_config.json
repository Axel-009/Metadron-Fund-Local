{
    "openbb": {
        "enabled": true,
        "cache_ttl_hours": 4,
        "default_provider": "yfinance",
        "fallback_to_yfinance": true
    },
    "camel_oasis": {
        "enabled": true,
        "n_agents_per_type": 10,
        "n_simulation_steps": 100,
        "shock_magnitude": 0.05,
        "propagation_decay": 0.7
    },
    "pysr_newton": {
        "enabled": true,
        "n_iterations": 40,
        "max_complexity": 20,
        "populations": 15,
        "population_size": 33
    },
    "qlib": {
        "enabled": true,
        "region": "us",
        "model_type": "lightgbm",
        "factor_set": "alpha158"
    },
    "transformers_bert": {
        "enabled": true,
        "sentiment_model": "ProsusAI/finbert",
        "device": "cpu"
    },
    "airllm": {
        "enabled": true,
        "model_size": "small",
        "fallback_to_finbert": true
    }
}
