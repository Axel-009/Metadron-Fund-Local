# Metadron Capital — Environment Variables
# Copy to .env and fill in your values

# --- Tradier Brokerage API ---
# Get your keys at https://web.tradier.com/user/api
TRADIER_API_KEY=your_sandbox_or_production_token
TRADIER_ACCOUNT_ID=your_account_id
TRADIER_ENVIRONMENT=sandbox  # "sandbox" or "production"

# --- OpenBB Data ---
# OPENBB_TOKEN=your_openbb_hub_token

# --- LLM APIs ---
# ANTHROPIC_API_KEY=your_anthropic_key
# OPENAI_API_KEY=your_openai_key

# --- MiroFish Social Engine ---
# LLM_API_KEY=your_llm_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini
# ZEP_API_KEY=your_zep_key
