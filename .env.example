# Metadron Capital — Environment Variables
# Copy to .env and fill in your values

# === 3 AUTHORIZED EXTERNAL APIs (all others prohibited) ===

# --- OpenBB / FMP (Market Data — sole data provider) ---
FMP_API_KEY=your_fmp_api_key_here
OPENBB_TOKEN=your_openbb_token_here

# --- Alpaca Brokerage API (Trade Execution) ---
# Get your keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_api_key
ALPACA_SECRET_KEY=your_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_PAPER_TRADE=     # REQUIRED — must be explicitly set to True or False (no default)
                          # System will refuse to start if this is not set

# --- Xiaomi Mimo V2 Pro (Brain Power — LLM / Intelligence) ---
XIAOMI_MIMO_API_KEY=your_xiaomi_mimo_v2_pro_api_key_here

# === Infrastructure (internal — not external APIs) ===

# Database (used by engine/db/database.py)
METADRON_DATABASE_URL=sqlite:///data/metadron.db

# Redis (optional — for caching)
# REDIS_URL=redis://localhost:6379/0

# Engine API
ENGINE_API_PORT=8001
ENGINE_API_HOST=0.0.0.0

# LLM Bridge
LLM_BRIDGE_PORT=8002
LLM_BRIDGE_HOST=0.0.0.0

# Frontend / Express
FRONTEND_PORT=5000

# === ZEP — Miro Fish / Agent Simulation (internal memory layer) ===
ZEP_API_URL=http://localhost:8003
ZEP_API_KEY=your_zep_api_key_here
ZEP_COLLECTION=metadron_agents
