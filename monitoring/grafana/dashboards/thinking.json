      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(metadron_scan_cycle_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "editorMode": "code",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.90, sum(rate(metadron_scan_cycle_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "B",
          "editorMode": "code",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(metadron_scan_cycle_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "editorMode": "code",
          "range": true
        }
      ]
    },
