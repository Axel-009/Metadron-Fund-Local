        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 19 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "metadron_capital_deployment_rate{job=\"engine-api\"}",
          "legendFormat": "Capital Deploy ($/min)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(metadron_capital_deployment_rate{job=\"engine-api\"}[5m])",
          "legendFormat": "5m Moving Avg",
          "refId": "B"
        }
      ],
      "title": "Capital Deployment Rate ($/min)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Momentum",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Composite momentum score — aggregated across all active signals and engines. Range: -100 (extreme bearish) to +100 (extreme bullish)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
