# =============================================================================
# .env.production.example — Metadron Capital Production Environment Variables
# Hetzner GEX44 / Ubuntu 22.04
#
# USAGE:
#   cp .env.production.example .env.production
#   nano .env.production           # fill in all secrets
#   chmod 600 .env.production      # never world-readable
#
# SECRETS MANAGEMENT:
#   Consider using doppler, vault, or AWS Secrets Manager for production.
#   At minimum, ensure .env.production is in .gitignore and never committed.
#
# REQUIRED vs OPTIONAL:
#   Required = application will fail to start without this value
#   Optional = feature is disabled or falls back to a default
# =============================================================================

# ---------------------------------------------------------------------------
# General application settings
# ---------------------------------------------------------------------------

# Node environment — must be "production" on this server
NODE_ENV=production

# Express frontend port (NGINX proxies /terminal/ and /api/engine/ here)
PORT=5000

# FastAPI engine API port (internal — not exposed to NGINX directly)
ENGINE_API_PORT=8001

# LLM Inference Bridge port
LLM_BRIDGE_PORT=8002

# Air-LLM server port
AIRLLM_PORT=8003

# Qwen model server port (Gradio/FastAPI)
QWEN_PORT=7860

# MiroFish backend port
MIROFISH_API_PORT=5001

# MiroFish frontend dev server port (only active in dev; in prod, served as static)
MIROFISH_FRONTEND_PORT=5174

# Domain and base URL
DOMAIN=metadroncapital.com
BASE_URL=https://metadroncapital.com

# ---------------------------------------------------------------------------
# Anthropic Claude API  [REQUIRED for LLM features]
# Get key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# Anthropic model to use (claude-3-5-sonnet-20241022 recommended for production)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---------------------------------------------------------------------------
# Alpaca Trading API  [REQUIRED for trading engine]
# Paper trading vs live trading controlled by ALPACA_PAPER_TRADE
# Get keys at: https://app.alpaca.markets/ (paper) or https://app.alpaca.markets/brokerage/
# ---------------------------------------------------------------------------
ALPACA_API_KEY=xxx
ALPACA_SECRET_KEY=xxx

# Set to True for paper trading (safe default), False for live trading
# WARNING: ALPACA_PAPER_TRADE=False will execute real trades with real money
ALPACA_PAPER_TRADE=True

# Alpaca API base URLs (automatically selected based on ALPACA_PAPER_TRADE,
# but can be overridden here)
# ALPACA_BASE_URL=https://paper-api.alpaca.markets    # paper
# ALPACA_BASE_URL=https://api.alpaca.markets          # live
# ALPACA_DATA_URL=https://data.alpaca.markets

# ---------------------------------------------------------------------------
# Financial Modeling Prep (FMP)  [REQUIRED for market data]
# Get key at: https://financialmodelingprep.com/developer/docs/
# ---------------------------------------------------------------------------
FMP_API_KEY=xxx

# ---------------------------------------------------------------------------
# OpenBB Platform  [OPTIONAL — enhances market data]
# Get token at: https://my.openbb.co/
# ---------------------------------------------------------------------------
OPENBB_TOKEN=xxx

# ---------------------------------------------------------------------------
# Model paths for local inference
# Models are downloaded automatically on first run by HuggingFace transformers.
# Use full HuggingFace model IDs or local filesystem paths.
# ---------------------------------------------------------------------------

# Qwen2.5-Omni-7B for real-time multimodal market analysis
QWEN_MODEL_PATH=Qwen/Qwen2.5-Omni-7B

# LLaMA 3.1 70B for deep analysis via Air-LLM (layer-by-layer inference)
# Air-LLM allows running 70B+ models on single-GPU systems by offloading layers
AIRLLM_MODEL_PATH=meta-llama/Llama-3.1-70B

# HuggingFace access token (required for gated models like LLaMA)
# Get at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxx

# Local cache directory for downloaded models (leave default for HF cache)
# HF_HOME=/opt/metadron/models/.cache
# TRANSFORMERS_CACHE=/opt/metadron/models/.cache/transformers

# ---------------------------------------------------------------------------
# GPU / CUDA configuration
# ---------------------------------------------------------------------------

# Which GPU(s) to expose to the process (0 = first GPU, "0,1" for multi-GPU)
CUDA_VISIBLE_DEVICES=0

# Optional: set CUDA memory fraction to avoid OOM (0.0–1.0)
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# ---------------------------------------------------------------------------
# Database  [OPTIONAL — if using persistent storage]
# ---------------------------------------------------------------------------

# PostgreSQL (if using a relational DB for trade history)
# DATABASE_URL=postgresql://metadron:<password>@localhost:5432/metadron_prod

# Redis (for session cache, rate limiting, pub/sub)
# REDIS_URL=redis://localhost:6379/0

# SQLite fallback (used if DATABASE_URL not set)
SQLITE_DB_PATH=/opt/metadron/data/metadron.db

# ---------------------------------------------------------------------------
# Authentication / Security  [REQUIRED]
# ---------------------------------------------------------------------------

# JWT secret for signing session tokens — use a long random string
# Generate with: openssl rand -hex 64
JWT_SECRET=xxx

# Session secret for Express sessions
SESSION_SECRET=xxx

# API key for internal service-to-service auth (engine ↔ bridge ↔ frontend)
INTERNAL_API_KEY=xxx

# ---------------------------------------------------------------------------
# Trading schedule  [OPTIONAL — override defaults]
# Markets use US/Eastern timezone (ET)
# ---------------------------------------------------------------------------

# Market open task — runs daily at 9:25 AM ET (before 9:30 open)
CRON_MARKET_OPEN="25 9 * * 1-5"

# Market close task — runs daily at 3:55 PM ET (before 4:00 close)
CRON_MARKET_CLOSE="55 15 * * 1-5"

# Hourly rebalance/signal check — every hour during market hours
CRON_HOURLY="0 10-15 * * 1-5"

# Post-market analysis — 4:30 PM ET weekdays
CRON_POST_MARKET="30 16 * * 1-5"

# Timezone for cron jobs (PM2 cron_restart and internal schedulers)
TZ=America/New_York

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Log file paths (PM2 also writes to ~/.pm2/logs/)
LOG_DIR=/var/log/metadron
ACCESS_LOG=/var/log/metadron/access.log
ERROR_LOG=/var/log/metadron/error.log

# ---------------------------------------------------------------------------
# NGINX / Reverse proxy
# ---------------------------------------------------------------------------

# Trust proxy headers (set to 1 when behind Cloudflare/NGINX)
TRUST_PROXY=1

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://metadroncapital.com,https://www.metadroncapital.com

# ---------------------------------------------------------------------------
# Email / Alerting  [OPTIONAL]
# For PM2 process crash notifications and trading alerts
# ---------------------------------------------------------------------------

# SMTP settings (or use SendGrid/SES)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxx
# ALERT_EMAIL=ops@metadroncapital.com

# Slack webhook for trade alerts and errors
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ---------------------------------------------------------------------------
# Prometheus / Monitoring  [OPTIONAL — exporters read some of these]
# ---------------------------------------------------------------------------

# Metrics endpoint auth token (if you add bearer auth to /metrics)
# METRICS_TOKEN=xxx

# WireGuard monitoring VPS address (for reference in app health checks)
MONITORING_VPS_IP=10.0.0.2

# ---------------------------------------------------------------------------
# MiroFish-specific  [REQUIRED if MiroFish is active]
# ---------------------------------------------------------------------------

# MiroFish database
# MIROFISH_DB_URL=postgresql://metadron:<password>@localhost:5432/mirofish_prod

# MiroFish API secret
# MIROFISH_SECRET=xxx

# ---------------------------------------------------------------------------
# Air-LLM specific  [OPTIONAL — performance tuning]
# ---------------------------------------------------------------------------

# Number of GPU layers to offload (higher = faster, more VRAM)
# AIRLLM_GPU_LAYERS=80

# Compression mode for Air-LLM (none | 4bit | 8bit)
AIRLLM_COMPRESSION=4bit

# ---------------------------------------------------------------------------
# Qwen-specific
# ---------------------------------------------------------------------------

# Qwen device map (auto | cuda:0 | cpu)
QWEN_DEVICE=cuda:0

# Qwen data type (float16 | bfloat16 | float32)
QWEN_DTYPE=bfloat16
